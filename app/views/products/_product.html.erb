<div id="<%= dom_id product %>">
  <p>
    <strong>Title:</strong>
    <%= product.title %>
  </p>

  <p>
    <strong>Descrption:</strong>
    <%= product.descrption %>
  </p>

  <p>
    <strong>Images:</strong>
    <% product.images.each do |img| %>
      <%= image_tag url_for(img) %><br>
    <% end %>
  </p>
</div>
